            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-maybe">~</span></td>
            <td class="ibr-td-ideas"><span class="ibr-yes">✓</span></td>
          </tr>
          <tr>
            <td>CSS isolated per widget (no global leakage)</td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-no">✗</span></td>
            <td class="ibr-td-ideas"><span class="ibr-yes">✓</span></td>
          </tr>
          <tr>
            <td>JS isolated per widget (IIFE, no globals)</td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-no">✗</span></td>
            <td class="ibr-td-ideas"><span class="ibr-yes">✓</span></td>
          </tr>
          <tr>
            <td>Theme never wraps admin UI</td>
            <td><span class="ibr-no">✗</span></td>
            <td><span class="ibr-maybe">~</span></td>
            <td><span class="ibr-yes">✓</span></td>
            <td><span class="ibr-yes">✓</span></td>
