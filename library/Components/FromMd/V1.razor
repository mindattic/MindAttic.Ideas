@namespace MindAttic.Ideas.Component.FromMd
@inherits ComponentBase
@attribute [Idea(DisplayName = "Markdown Doc")]
@attribute [Uses(ContentKind.Plugin, "header", 1)]

<link rel="stylesheet" href="/_ideas/Component/frommd/1/frommd.css" />

@if (renderedHtml is not null)
{
    <div class="ma-frommd @CssClass" style="@_outerStyle">@((MarkupString)renderedHtml)</div>
}
else
{
    <div class="ma-frommd ma-frommd-empty @CssClass" style="@_outerStyle">
        <p><em>No content loaded. In edit mode, set a source file path and click "Update from Source".</em></p>
    </div>
}

@if (EditMode)
{
    <div class="ma-frommd-admin">
        @if (error is not null)
        {
            <p class="ma-frommd-error">@error</p>
        }

        <div class="ma-frommd-admin-row">
            <input type="text" placeholder="Source file path (e.g. D:/Projects/MyApp/README.md)"
                   @bind="localSourceFile" @bind:event="oninput" class="ma-frommd-srcpath" />
            <button @onclick="UpdateFromSourceAsync" disabled="@updating">
                @(updating ? "Updating…" : "Update from Source")
            </button>
        </div>

        @if (lastSynced is not null)
        {
            <small class="ma-frommd-synced">Last synced: @lastSynced.Value.ToString("yyyy-MM-dd HH:mm") UTC</small>
        }
    </div>
}

@code {
    /// <summary>
    /// Instance discriminator — use "main" (default) when there is only one FromMd per page,
    /// or a custom name (e.g. "api-docs") when multiple instances coexist on the same page.
    /// </summary>
    [Parameter] public string Slot { get; set; } = "main";

    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string? CssStyle { get; set; }
    [Parameter] public string? Padding { get; set; }
    [Parameter] public string? Margin { get; set; }
    [Parameter] public string? Align { get; set; }

    private string _outerStyle => string.Join(";", new[]
    {
        string.IsNullOrEmpty(Padding) ? null : $"padding:{Padding}",
        string.IsNullOrEmpty(Margin)  ? null : $"margin:{Margin}",
        string.IsNullOrEmpty(Align) ? null : $"text-align:{Align}",
        CssStyle,
    }.Where(s => s is not null));

    string? renderedHtml;
    string? localSourceFile;
    DateTime? lastSynced;
    string? error;
    bool updating;

    IComponentMetadataStore? store;

    protected override async Task OnInitializedAsync()
    {
        Context.TryGetFeature(out store);
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (store is null) return;
        var json = await store.GetAsync(Context.Page.PageId, "frommd", Slot);
        if (json is null) return;
        var settings = Deserialize(json);
        if (settings is null) return;
        localSourceFile = settings.LocalSourceFile;
        lastSynced = settings.LastSynced;
        renderedHtml = string.IsNullOrEmpty(settings.Markdown)
            ? null
            : Markdig.Markdown.ToHtml(settings.Markdown, Pipeline);
    }

    async Task UpdateFromSourceAsync()
    {
        if (store is null) { error = "Metadata store not available."; return; }
        if (string.IsNullOrWhiteSpace(localSourceFile)) { error = "Enter a source file path first."; return; }
        var ext = Path.GetExtension(localSourceFile);
        if (!ext.Equals(".md", StringComparison.OrdinalIgnoreCase) && !ext.Equals(".markdown", StringComparison.OrdinalIgnoreCase))
        {
            error = "Only .md / .markdown files are supported.";
            return;
        }
        error = null;
        updating = true;
        try
        {
            if (!File.Exists(localSourceFile)) { error = $"File not found: {localSourceFile}"; return; }
            var markdown = await File.ReadAllTextAsync(localSourceFile);
            var synced = DateTime.UtcNow;
            var json = Serialize(new FromMdSettings
            {
                LocalSourceFile = localSourceFile,
                Markdown = markdown,
                LastSynced = synced,
            });
            await store.SaveAsync(Context.Page.PageId, "frommd", Slot, json);
            lastSynced = synced;
            renderedHtml = Markdig.Markdown.ToHtml(markdown, Pipeline);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            updating = false;
        }
    }

    // ---- private helpers ----

    static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new(System.Text.Json.JsonSerializerDefaults.Web);

    static readonly Markdig.MarkdownPipeline Pipeline =
        new Markdig.MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();

    static FromMdSettings? Deserialize(string json) =>
        System.Text.Json.JsonSerializer.Deserialize<FromMdSettings>(json, JsonOpts);

    static string Serialize(FromMdSettings s) =>
        System.Text.Json.JsonSerializer.Serialize(s, JsonOpts);

    sealed class FromMdSettings
    {
        public string? LocalSourceFile { get; set; }
        public string? Markdown { get; set; }
        public DateTime? LastSynced { get; set; }
    }
}
