@namespace MindAttic.Ideas.Component.MindAtticFrontpage
@inherits ComponentBase
@attribute [Uses(ContentKind.Component, "tabs", 1)]
@attribute [Uses(ContentKind.Component, "gallery", 1)]
@attribute [Uses(ContentKind.Plugin, "footer", 1)]

@* MindAttic.Ideas.Component.MindAtticFrontpage.V1
   Content is owned as ComponentMetadata JSON (IComponentMetadataStore seam). Falls back to
   built-in defaults on first render; admin can initialize + edit via the JSON panel in Edit mode. *@
<CmsInclude Ref="MindAttic.Ideas.Component.Tabs.V1" />
<CmsInclude Ref="MindAttic.Ideas.Component.Gallery.V1" />
<CmsInclude Ref="MindAttic.Ideas.Plugin.Footer.V1" />

<link rel="stylesheet" href="/_ideas/Component/mindatticfrontpage/1/maf.css" />

<div class="maf">
    <header class="maf-header">
        <h1 class="maf-wordmark">@settings.Wordmark</h1>
    </header>

    <main class="maf-sections">
        @foreach (var section in settings.Sections)
        {
            <section class="maf-section">
                <h2>@section.Title</h2>

                @if (section.Type == "links")
                {
                    <nav class="maf-links" aria-label="@section.Title">
                        @foreach (var item in section.Items)
                        {
                            <a href="@item.Url" target="_blank" rel="noopener noreferrer">@item.Title</a>
                        }
                    </nav>
                }
                else if (section.Type == "tabs")
                {
                    <div class="ma-tabs ma-tabs-board" data-closed>
                        @foreach (var item in section.Items)
                        {
                            <section data-title="@item.Title">
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p>@item.Description</p>
                                }
                                <p>
                                    @if (!string.IsNullOrEmpty(item.IdeaSlug))
                                    {
                                        <a href="/projects/@item.IdeaSlug">Details</a>
                                        @if (!string.IsNullOrEmpty(item.Url))
                                        {
                                            <text> · </text>
                                        }
                                    }
                                    @if (!string.IsNullOrEmpty(item.Url))
                                    {
                                        <a href="@item.Url" target="_blank" rel="noopener noreferrer">Open</a>
                                    }
                                </p>
                            </section>
                        }
                    </div>
                }
                else if (section.Type == "gallery")
                {
                    <div class="ma-gallery maf-books">
                        @foreach (var item in section.Items)
                        {
                            <a class="ma-gallery-tile @item.CssClass" href="@item.Url" target="_blank" rel="noopener noreferrer">
                                <span>@item.Title</span>
                            </a>
                        }
                    </div>
                }
            </section>
        }
    </main>

    <footer class="ma-footer">© <span class="maf-year">@DateTime.UtcNow.Year</span> @settings.CopyrightName</footer>
</div>

@if (EditMode)
{
    <div class="maf-admin">
        @if (error is not null)
        {
            <p class="maf-admin-error">@error</p>
        }
        <div class="maf-admin-toolbar">
            @if (!editing)
            {
                <button @onclick="BeginEdit">Edit Content JSON</button>
            }
            else
            {
                <button @onclick="SaveEdit" disabled="@saving">@(saving ? "Saving…" : "Save")</button>
                <button @onclick="CancelEdit">Cancel</button>
            }
        </div>
        @if (editing)
        {
            <textarea class="maf-admin-json" @bind="draftJson" rows="30" spellcheck="false"></textarea>
        }
    </div>
}

@code {
    [Parameter] public string Slot { get; set; } = "main";

    MafSettings settings = new();
    IComponentMetadataStore? store;

    bool editing;
    bool saving;
    string? draftJson;
    string? error;

    protected override async Task OnInitializedAsync()
    {
        Context.TryGetFeature(out store);
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (store is null) { settings = DefaultSettings(); return; }
        var json = await store.GetAsync(Context.Page.PageId, "mindatticfrontpage", Slot);
        settings = json is null ? DefaultSettings() : (Deserialize(json) ?? DefaultSettings());
    }

    void BeginEdit()
    {
        draftJson = System.Text.Json.JsonSerializer.Serialize(settings, new System.Text.Json.JsonSerializerOptions
            { WriteIndented = true, PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
        editing = true;
        error = null;
    }

    void CancelEdit() { editing = false; draftJson = null; error = null; }

    async Task SaveEdit()
    {
        if (store is null) { error = "Metadata store not available."; return; }
        if (string.IsNullOrWhiteSpace(draftJson)) { error = "JSON cannot be empty."; return; }
        saving = true; error = null;
        try
        {
            var parsed = Deserialize(draftJson);
            if (parsed is null) { error = "Invalid JSON — could not parse."; return; }
            await store.SaveAsync(Context.Page.PageId, "mindatticfrontpage", Slot, draftJson);
            settings = parsed;
            editing = false;
            draftJson = null;
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; }
    }

    // ---- Helpers ----

    static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new(System.Text.Json.JsonSerializerDefaults.Web) { WriteIndented = false };

    static MafSettings? Deserialize(string json) =>
