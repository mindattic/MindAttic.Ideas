@namespace MindAttic.Ideas.Component.TableOfContents
@inherits ComponentBase

@* MindAttic.Ideas.Component.TableOfContents.V1 — an OPTIONAL table of contents. Add it to a page and it
   renders that page's full descendant hierarchy (children, grandchildren, …) as a nested nav list.
   Add it to a leaf page (no children) and it renders NOTHING — harmless either way. It reads the tree
   from the host IPageTree feature through the render context, with no compile-time host reference. *@
@if (_tree.Count > 0)
{
    @* Styling loads only when the ToC actually renders (leaf pages emit nothing at all). *@
    <link rel="stylesheet" href="/_ideas/Component/tableofcontents/1/toc.css" />
    <nav class="ma-toc" aria-label="Table of contents">
        @BuildList(_tree)
    </nav>
}

@code {
    private IReadOnlyList<ChildPageNode> _tree = Array.Empty<ChildPageNode>();

    protected override async Task OnParametersSetAsync()
    {
        if (Context is not null && Context.TryGetFeature<IPageTree>(out var tree) && tree is not null)
            _tree = await tree.DescendantsTreeAsync(Context.Page.PageId);
    }

    private RenderFragment BuildList(IReadOnlyList<ChildPageNode> nodes) => builder =>
    {
        int seq = 0;
        builder.OpenElement(seq++, "ul");
        builder.AddAttribute(seq++, "class", "ma-toc-list");
        foreach (var node in nodes)
        {
            builder.OpenElement(seq++, "li");
            builder.AddAttribute(seq++, "class", "ma-toc-item");
            builder.OpenElement(seq++, "a");
            builder.AddAttribute(seq++, "class", "ma-toc-link");
            builder.AddAttribute(seq++, "href", "/" + node.Slug);
            builder.AddContent(seq++, node.Title);
            builder.CloseElement(); // a
            if (node.Children.Count > 0)
                builder.AddContent(seq++, BuildList(node.Children));
            builder.CloseElement(); // li
        }
        builder.CloseElement(); // ul
    };
}
