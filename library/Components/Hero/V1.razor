@namespace MindAttic.Ideas.Component.Hero
@inherits ComponentBase
@attribute [Idea(DisplayName = "Hero")]

@* MindAttic.Ideas.Component.Hero.V1 — a full-width hero banner: title, optional subtitle, optional
   call-to-action button, optional background image with a darkening overlay so text stays readable.
   All knobs are string [Parameter]s (data-page token attributes arrive as strings — typed coercion
   is RFC 0001 roadmap). The background follows the page-authoring convention that images live as
   inline base64 CSS classes in the page's CSS: pass that class via imageclass=. (image= also accepts
   a URL/data: URI directly.)
   {{ MindAttic.Ideas.Component.Hero title="Welcome" imageclass="img-sky" ctatext="Get started" ctahref="/docs" }} *@
<link rel="stylesheet" href="/_ideas/Component/hero/1/hero.css" />
<section class="@_rootClass" style="@_outerStyle">
    <div class="ma-hero-inner">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <h1 class="ma-hero-title">@Title</h1>
        }
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p class="ma-hero-subtitle">@Subtitle</p>
        }
        @if (!string.IsNullOrWhiteSpace(CtaText) && !string.IsNullOrWhiteSpace(CtaHref))
        {
            <a class="ma-hero-cta" href="@SafeUrl(CtaHref)">@CtaText</a>
        }
    </div>
</section>

@code {
    /// <summary>The headline.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Optional line under the headline.</summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>A page CSS class carrying the base64 background-image (the authoring convention).</summary>
    [Parameter] public string? ImageClass { get; set; }

    /// <summary>Optional background image URL or data: URI (alternative to ImageClass).</summary>
    [Parameter] public string? Image { get; set; }

    /// <summary>Call-to-action button text (rendered only with CtaHref).</summary>
    [Parameter] public string? CtaText { get; set; }

    /// <summary>Call-to-action link target.</summary>
    [Parameter] public string? CtaHref { get; set; }

    /// <summary>Horizontal alignment: center (default) | left | right.</summary>
    [Parameter] public string? Align { get; set; }

    /// <summary>Additional CSS classes appended to the root element.</summary>
    [Parameter] public string? CssClass { get; set; }

    /// <summary>Inline CSS appended to the root element's style attribute.</summary>
    [Parameter] public string? CssStyle { get; set; }

    /// <summary>CSS padding shorthand (e.g. "1rem" or "4px 8px").</summary>
    [Parameter] public string? Padding { get; set; }

    /// <summary>CSS margin shorthand.</summary>
    [Parameter] public string? Margin { get; set; }

    private bool HasImage => !string.IsNullOrWhiteSpace(ImageClass) || !string.IsNullOrWhiteSpace(Image);

    private string AlignClass => Align?.ToLowerInvariant() switch
    {
        "left" => "ma-hero-left",
        "right" => "ma-hero-right",
        _ => "ma-hero-center",
    };

    // Joins all conditional classes, skipping nulls/empties to avoid spurious spaces in the attribute.
    private string _rootClass => string.Join(" ",
        new[] { "ma-hero", AlignClass, HasImage ? $"ma-hero-img {ImageClass}".TrimEnd() : null, CssClass }
        .Where(s => !string.IsNullOrWhiteSpace(s)));

    // Single quotes are not HTML-encoded by Blazor, so escape them to keep Image inside the url('…') string.
    private string? BackgroundStyle => string.IsNullOrWhiteSpace(Image)
        ? null
        : $"background-image: url('{Image.Replace("'", "%27")}');";

    private string _outerStyle => string.Join(";", new[]
    {
        string.IsNullOrEmpty(Padding) ? null : $"padding:{Padding}",
        string.IsNullOrEmpty(Margin)  ? null : $"margin:{Margin}",
        BackgroundStyle,
        CssStyle,
    }.Where(s => s is not null));
}
