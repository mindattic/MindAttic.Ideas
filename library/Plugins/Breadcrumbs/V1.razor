@namespace MindAttic.Ideas.Plugin.Breadcrumbs
@inherits PluginBase
@attribute [Idea(DisplayName = "Breadcrumbs")]

@* MindAttic.Ideas.Plugin.Breadcrumbs.V1 — a breadcrumb trail derived LEXICALLY from the current
   page's slug segments ("docs/widgets/intro" -> Home / Docs / Widgets / Intro), so it needs no host
   tree feature and works on any page the moment it's dropped in. Intermediate crumbs link to the
   cumulative slug prefix; titles are prettified segment names ("my-page" -> "My Page"); the last
   crumb is the page's real Title. Renders nothing on the home page (no segments). *@
@if (_crumbs.Count > 0)
{
    <link rel="stylesheet" href="/_ideas/Plugin/breadcrumbs/1/breadcrumbs.css" />
    <nav class="ma-crumbs @CssClass" aria-label="Breadcrumb" style="@_outerStyle">
        <ol class="ma-crumbs-list">
            <li class="ma-crumbs-item"><a class="ma-crumbs-link" href="/">@_homeText</a></li>
            @foreach (var (text, href, isLast) in _crumbs)
            {
                <li class="ma-crumbs-item">
                    @if (isLast)
                    {
                        <span class="ma-crumbs-current" aria-current="page">@text</span>
                    }
                    else
                    {
                        <a class="ma-crumbs-link" href="@href">@text</a>
                    }
                </li>
            }
        </ol>
    </nav>
}

@code {
    /// <summary>Text of the leading root crumb (default "Home").</summary>
    [Parameter] public string? Home { get; set; }

    /// <summary>Additional CSS classes appended to the root element.</summary>
    [Parameter] public string? CssClass { get; set; }

    /// <summary>Inline CSS appended to the root element's style attribute.</summary>
    [Parameter] public string? CssStyle { get; set; }

    /// <summary>CSS padding shorthand (e.g. "1rem" or "4px 8px").</summary>
    [Parameter] public string? Padding { get; set; }

    /// <summary>CSS margin shorthand.</summary>
    [Parameter] public string? Margin { get; set; }

    /// <summary>text-align or flex justification (e.g. "center", "left", "right").</summary>
    [Parameter] public string? Align { get; set; }

    private string _outerStyle => string.Join(";", new[]
    {
        string.IsNullOrEmpty(Padding) ? null : $"padding:{Padding}",
        string.IsNullOrEmpty(Margin)  ? null : $"margin:{Margin}",
        string.IsNullOrEmpty(Align) ? null : $"text-align:{Align}",
        CssStyle,
    }.Where(s => s is not null));

    private IReadOnlyList<(string Text, string Href, bool IsLast)> _crumbs =
        Array.Empty<(string, string, bool)>();
    private string _homeText = "Home";

    protected override void OnParametersSet()
    {
        _homeText = string.IsNullOrWhiteSpace(Home) ? "Home" : Home;
        _crumbs = Build(Context?.Page?.Slug, Context?.Page?.Title);
    }

    private static IReadOnlyList<(string, string, bool)> Build(string? slug, string? title)
    {
        var segments = (slug ?? "").Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (segments.Length == 0 || (segments.Length == 1 && segments[0].Equals("home", StringComparison.OrdinalIgnoreCase)))
            return Array.Empty<(string, string, bool)>();
        var crumbs = new List<(string, string, bool)>();
        var prefix = "";
        for (var i = 0; i < segments.Length; i++)
        {
            prefix += "/" + segments[i];
            var isLast = i == segments.Length - 1;
            var text = isLast && !string.IsNullOrWhiteSpace(title) ? title! : Prettify(segments[i]);
            crumbs.Add((text, prefix, isLast));
        }
        return crumbs;
    }

    // "my-page" / "my_page" -> "My Page" (display only; the href keeps the raw segment).
    private static string Prettify(string segment)
    {
        var words = segment.Replace('-', ' ').Replace('_', ' ').Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join(' ', words.Select(w => char.ToUpperInvariant(w[0]) + w[1..]));
    }
}
