@page "/{*Slug}"
@namespace MindAttic.Ideas.Rendering
@*  One interactive circuit per content page: any stamped widget that needs interactivity (e.g. a
    LegionPersonas gallery) is live, sharing this ONE circuit — no per-widget app pool. PageHost is the
    interactive ROOT, so only its route param (Slug, a string) crosses the serialization boundary; the
    IRenderContext cascade + RenderFragment body it builds internally never serialize. (Future perf
    refinement: per-island render mode for purely-static pages — needs a serializable cascade first.) *@
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MindAttic.Authentication
@using MindAttic.Ideas.Core.Data
@using MindAttic.Ideas.Core.Entities
@using MindAttic.Ideas.Core.Services
@inject IDbContextFactory<CmsDbContext> DbFactory
@inject ISlugRedirectService SlugRedirects
@inject IContentCatalog Catalog
@inject IServiceProvider Services
@inject IRenderAlertSink Alerts
@inject NavigationManager Nav

@* The single, permanent render entry point for free-form pages. No zones. Resolution is by
   (SiteId, Slug) data lookup, never per-page routing — so a runtime-loaded type renders unchanged. *@

@if (_status == Status.NotFound)
{
    <PageTitle>Not found</PageTitle>
    <p class="ma-404">Page not found.</p>
}
else if (_status == Status.Forbidden)
{
    <PageTitle>Not found</PageTitle>
    <p class="ma-404">Page not found.</p>
}
else if (_context is not null)
{
    <PageTitle>@(_context.Page.SeoTitle ?? _context.Page.Title)</PageTitle>
    <HeadContent>
        @if (_context.Page.Meta.GetValueOrDefault("seo.description") is { Length: > 0 } desc)
        {
            <meta name="description" content="@desc" />
        }
        <CmsHead GlobalCss="@_globalCss"
                 ThemeGlobalCss="@_themeGlobalCss"
                 ThemeCss="@_themeCss"
                 ThemeScripts="@_themeScripts"
                 ComponentCss="@_componentCss"
                 ComponentScripts="@_componentScripts" />
    </HeadContent>

    <CascadingValue Value="_context" IsFixed="true">
        @if (_themeType is not null)
        {
            <DynamicComponent Type="_themeType" Parameters="_themeParams" />
        }
        else
        {
            <DynamicComponent Type="_bodyType" />
        }
    </CascadingValue>
}

@code {
    [Parameter] public string? Slug { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private enum Status { Pending, Ok, NotFound, Forbidden }
    private Status _status = Status.Pending;

    private IRenderContext? _context;
    private Type? _themeType;
    private Type _bodyType = typeof(FreeFormPage);
    private IDictionary<string, object>? _themeParams;
    private string? _globalCss;
    private IReadOnlyList<string> _themeGlobalCss = Array.Empty<string>();
    private IReadOnlyList<string> _themeCss = Array.Empty<string>();
    private IReadOnlyList<string> _themeScripts = Array.Empty<string>();
    private IReadOnlyList<string> _componentCss = Array.Empty<string>();
    private IReadOnlyList<string> _componentScripts = Array.Empty<string>();

    protected override async Task OnParametersSetAsync()
    {
        var slug = (Slug ?? "").Trim('/');

        // Reserved prefixes never resolve to a content page (defense in depth; /admin & /_* are also
        // handled by endpoint routing).
        if (slug.StartsWith("admin", StringComparison.OrdinalIgnoreCase) || slug.StartsWith('_'))
        {
            _status = Status.NotFound;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        // The bare route never renders content itself — it forwards to the site's front page
        // (Host setting "page.frontpage"; default slug "frontpage"). During prerender the
        // NavigationException this raises is converted by the framework into an HTTP redirect.
        if (slug.Length == 0)
        {
            var fp = await db.Settings.FirstOrDefaultAsync(s => s.Scope == "Host" && s.Key == "page.frontpage");
            Nav.NavigateTo("/" + (string.IsNullOrWhiteSpace(fp?.Value) ? "frontpage" : fp!.Value.Trim('/')), replace: true);
            return;
        }

        var site = await db.Sites.FirstOrDefaultAsync(s => s.IsDefault) ?? await db.Sites.FirstOrDefaultAsync();
        var siteId = site?.Id;
        var page = await db.Pages.Include(p => p.MetaTags).FirstOrDefaultAsync(p =>
            p.SiteId == siteId && p.Slug == slug && p.IsPublished && p.Enabled);

        if (page is null)
        {
            // Auto-301: before showing 404, check if this slug was renamed and a redirect entry exists.
            var redirect = await SlugRedirects.CheckRedirectAsync(siteId, slug);
            if (redirect is not null)
            {
                Nav.NavigateTo("/" + redirect.TargetSlug, false);
                return;
            }
            _status = Status.NotFound;
            return;
        }

        // Access control: if the page is restricted, verify the viewer has permission.
        if (page.IsRestricted)
        {
            var authState = AuthState is not null ? await AuthState : null;
            var user = authState?.User;

            if (user?.Identity?.IsAuthenticated != true)
            {
                Nav.NavigateTo("/_ma-auth/login?returnUrl=/" + Uri.EscapeDataString(slug), forceLoad: true);
                return;
            }

            var userRole = user.FindFirstValue(ClaimTypes.Role);
            var userId = user.FindFirstValue("ma:uid");

            // Admins always have access.
            bool hasAccess = userRole == MaRoles.Admin;

            if (!hasAccess)
            {
                var allowedRoles = await db.PageRoleAccess.Where(x => x.PageId == page.Id)
                    .Select(x => x.RoleName).ToListAsync();

                // Auth role match.
                if (userRole is not null && allowedRoles.Contains(userRole))
                    hasAccess = true;

                // CMS role match.
                if (!hasAccess && userId is not null)
                {
                    var cmsRoleNames = await db.CmsUserRoles
                        .Where(ur => ur.UserId == userId)
                        .Join(db.CmsRoles, ur => ur.RoleId, r => r.Id, (ur, r) => r.Name)
                        .ToListAsync();
                    hasAccess = cmsRoleNames.Any(r => allowedRoles.Contains(r));
                }

                // Per-user access.
                if (!hasAccess && userId is not null)
                    hasAccess = await db.PageUserAccess.AnyAsync(x => x.PageId == page.Id && x.UserId == userId);
            }

            if (!hasAccess)
            {
                _status = Status.Forbidden;
                return;
            }
        }

        var inline = new CmsInlineMarkup
        {
            Html = page.BodyHtml,
            Css = page.PageCss,
            Js = page.PageJs,
            Trusted = page.BodyTrust == ContentTrust.Author,
        };
        var seoDict = page.MetaTags.ToDictionary(t => t.Name, t => (string?)t.Content);

        var pageCtx = new CmsPageContext
        {
            PageId = page.Uid, Slug = page.Slug, Title = page.Title, SeoTitle = page.SeoTitle,
            ThemeKey = page.ThemeKey, ThemeVersion = page.ThemeVersion, Inline = inline,
            Meta = seoDict,
        };
        var siteCtx = new CmsSiteContext
        {
            SiteId = site?.Uid ?? Guid.Empty, Key = site?.Key ?? "default", Host = "",
            DefaultThemeKey = site?.DefaultThemeKey ?? "",
        };
        _context = new CmsRenderContext
        {
            InstanceId = Guid.NewGuid(), Mode = ContentMode.View, RenderMode = CmsRenderMode.InteractiveServer,
            Page = pageCtx, Site = siteCtx, Services = Services, RawSettingsJson = page.SettingsJson,
        };

        // Body type: Data -> FreeFormPage; Code -> resolved type; unresolved -> placeholder.
        if (page.Kind == PageKind.Code && page.ComponentTypeName is not null)
        {
            // Prefer the CATALOG's descriptor for this compiled type: it carries the correct Origin
            // (Package vs Compiled), Category, Key, Version and AssetMount — so a PACKAGE page is loaded
            // through the collectible ALC. A bare inline descriptor defaults to Origin=Compiled (and an
            // empty Category), which the AlcAwareTypeResolver routes to the default resolver, so a package
            // page's type would never load and the page would degrade to the missing-page placeholder.
            var desc = Catalog.All.FirstOrDefault(d => d.Kind == ContentKind.Page
                          && string.Equals(d.ClrTypeName, page.ComponentTypeName, StringComparison.Ordinal))
                       ?? new ContentDescriptor
                          {
                              Kind = ContentKind.Page, Key = page.Slug, Version = 1, DisplayName = page.Title,
                              Strategy = RenderStrategy.ClrType, ClrTypeName = page.ComponentTypeName,
                              AssemblyName = page.AssemblyName ?? "",
                          };
            var resolvedBody = Catalog.ResolveType(desc);
            _bodyType = resolvedBody ?? typeof(MissingPageHost);
            if (resolvedBody is null)
            {
                // A Code page whose compiled type is missing/renamed -> placeholder + alert (never a crash).
                try { Alerts.RaiseMissing(ContentKind.Page, page.Slug, null, page.Uid, page.Slug); } catch { }
            }
        }
        else
        {
            _bodyType = typeof(FreeFormPage);
        }

        // Theme: page override -> site default -> bootstrap fallback.
        var themeKey = page.ThemeKey ?? site?.DefaultThemeKey;
        var themeVersion = page.ThemeVersion ?? site?.DefaultThemeVersion ?? 1;
        if (!string.IsNullOrWhiteSpace(themeKey))
        {
            var themeRes = Catalog.ResolveTag(ContentKind.Theme, themeKey!, page.ThemeVersion);
            if (themeRes.Outcome == ContentResolution.Resolved)
            {
                _themeType = themeRes.Type;
            }
            else
            {
                // Requested theme missing/disabled -> fall back to bootstrap, and surface an Admin Inbox
                // alert so the broken reference is never silent (the page still renders).
                var fallback = Catalog.FindLatest(ContentKind.Theme, "bootstrap");
                _themeType = fallback is null ? null : Catalog.ResolveType(fallback);
                try
                {
                    if (themeRes.Outcome == ContentResolution.Disabled)
                        Alerts.RaiseDisabled(ContentKind.Theme, themeKey!, page.ThemeVersion, page.Uid, page.Slug);
                    else
                        Alerts.RaiseMissing(ContentKind.Theme, themeKey!, page.ThemeVersion, page.Uid, page.Slug);
                }
                catch { /* alerting never breaks a render */ }
            }
        }

        if (_themeType is not null && Activator.CreateInstance(_themeType) is ThemeBase meta)
        {
            _themeGlobalCss = meta.GlobalCssUrls;
            _themeCss = meta.ThemeCssUrls;
            _themeScripts = meta.ScriptUrls;
        }

        // Hoist + dedupe the head assets of the PACKAGE citizens this page includes (the no-schema
        // manifest->Extra data path feeds PageAssets.PackageAssetsOf; the collector + path are NUnit-tested
        // in Core). A DATA page's references come from its BodyHtml include tags; a CODE page has no BodyHtml,
        // so its references come from the manifest uses[] declared via [Uses] (surfaced onto the page
        // descriptor's Extra at reload). Both feed the SAME collector, so the head never disagrees with the
        // body about which citizen/version is on the page. Empty unless a citizen with assets is referenced.
        var refs = new List<(ContentKind, string, int?)>(IncludeReferenceParser.Parse(page.BodyHtml));
        if (page.Kind == PageKind.Code && page.ComponentTypeName is not null)
        {
            var pageDesc = Catalog.All.FirstOrDefault(d => d.Kind == ContentKind.Page
                && string.Equals(d.ClrTypeName, page.ComponentTypeName, StringComparison.Ordinal));
            if (pageDesc is not null)
                refs.AddRange(IncludeReferenceParser.ParseUses(ManifestAssetPacker.UsesFromExtra(pageDesc.Extra)));
        }
        var head = PageAssetCollector.Collect(refs, Catalog, d => PageAssets.AllAssetsOf(d, Catalog));
        _componentCss = head.Css;
        _componentScripts = head.Scripts;

        var globalSetting = await db.Settings.FirstOrDefaultAsync(s => s.Scope == "Host" && s.Key == "css.global");
        _globalCss = globalSetting?.Value;

        var bodyType = _bodyType;
        _themeParams = new Dictionary<string, object>
        {
            ["Body"] = (RenderFragment)(b => { b.OpenComponent(0, bodyType); b.CloseComponent(); }),
        };

        _status = Status.Ok;
    }
}
