# ---------------------------------------------------------------------------
# DEV-ONLY auth bypass for MindAttic.Authentication.
# Copy this file to ".env" (same folder) and fill in the password.
#
# The bypass auto-signs-in the user below ONLY when ALL hold:
#   - the app is running in the Development environment, AND
#   - the request comes from localhost (loopback), AND
#   - MA_DEV_AUTH_ENABLED=true here.
# It is also COMPILED OUT of release builds of MindAttic.Authentication
# (the code only exists in Debug-built packages). It can never run in prod.
#
# ".env" is gitignored — never commit real credentials.
# ---------------------------------------------------------------------------
MA_DEV_AUTH_ENABLED=true
MA_DEV_AUTH_USERNAME=admin
MA_DEV_AUTH_PASSWORD=
