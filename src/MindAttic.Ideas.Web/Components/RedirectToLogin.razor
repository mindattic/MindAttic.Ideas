@inject NavigationManager Nav

@code {
    // Static-SSR redirect for AuthorizeRouteView's NotAuthorized: an anonymous request to an
    // [Authorize] page is sent to the library login page, preserving the original URL as returnUrl.
    protected override void OnInitialized()
    {
        var returnUrl = Uri.EscapeDataString(new Uri(Nav.Uri).PathAndQuery);
        Nav.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
    }
}
