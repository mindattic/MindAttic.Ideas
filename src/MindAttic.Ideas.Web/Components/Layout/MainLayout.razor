@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using MindAttic.Authentication

@* Auth chrome — AuthorizeView-gated, so anonymous CMS visitors see nothing. UserCircle (upper-right)
   gives sign-out; the admin User-Management link sits beside it; UserTimeout arms the 30-min idle
   auto-logout only when authenticated. *@
<div style="display:inline-block;">
    <AuthorizeView Policy="@MaPolicies.Admin">
        @* One entry point: the tabbed admin shell (Page Management / Idea Library / Upload Idea /
           Settings / Attributions). *@
        <a href="/admin" style="color:#9aa3af;font-size:.85rem;text-decoration:none;">Admin</a>
    </AuthorizeView>
    <UserCircle ShowProfileCircle="false" />
</div>
<UserTimeout />

@Body

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
