@page "/account/change-password"
@using Microsoft.AspNetCore.Authorization
@using MindAttic.Authentication.Components
@attribute [Authorize]

<PageTitle>Change password</PageTitle>

<div class="ma-auth-page">
    <h1>Change password</h1>
    @* Forced-step landing page. MaChangePassword posts to /_ma-auth/change-password (current-password
       verification); success → /account?changed=1, failure → /account/change-password?error=1. *@
    <MaChangePassword Error="@(Error == 1)" />
</div>

@code {
    [SupplyParameterFromQuery] public int Error { get; set; }
}
