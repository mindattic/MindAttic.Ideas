@attribute [Authorize(Policy = MaPolicies.Admin)]

@* Attributions tab — credit for the third-party work MindAttic.Ideas builds on. First and
   foremost the CSS reset: the admin starts from Eric Meyer's reset so installed themes can't
   bleed into it (see the .ma-admin isolation block in app.css). *@

<p class="ma-attrib-lead">MindAttic.Ideas stands on the shoulders of others. With thanks:</p>

<div class="ma-attrib">
    <div class="ma-attrib-item">
        <h3>CSS Reset — Eric Meyer</h3>
        <p>
            The admin UI is reset to a clean baseline using Eric Meyer's public-domain
            <em>Reset CSS</em> — the canonical "clear every browser default" stylesheet. It's the
            reason a fully-themed site can't reach in and break this control panel.
        </p>
        <p><a href="https://meyerweb.com/eric/tools/css/reset/" target="_blank" rel="noopener noreferrer">meyerweb.com/eric/tools/css/reset</a> · public domain</p>
    </div>

    <div class="ma-attrib-item">
        <h3>AngleSharp</h3>
        <p>HTML parsing for the include-tag grammar and content sanitisation.</p>
        <p><a href="https://anglesharp.github.io/" target="_blank" rel="noopener noreferrer">anglesharp.github.io</a> · MIT</p>
    </div>

    <div class="ma-attrib-item">
        <h3>BCrypt.Net-Next</h3>
