@attribute [Authorize(Policy = MaPolicies.Admin)]

@* Settings tab — admin-wide concerns that aren't a specific page or package: the alert inbox
   (raised when a page references a missing/disabled .idea), user management, and a note on the
   admin's deliberate isolation from installed content. *@

<div class="ma-settings">
    <section>
        <h2>Users</h2>
        <p>Create, lock, and manage administrator accounts.</p>
        <p><a href="/users">Open user management →</a></p>
    </section>

    <section>
        <h2>Admin isolation</h2>
        <p>
            This control panel runs <strong>outside</strong> the Theme/Widget (<code>.idea</code>) world.
            No installed package's CSS or JavaScript — and not the site-wide <code>css.global</code> setting —
            is ever loaded here, so a broken or hostile package can never style or break the admin.
        </p>
    </section>

    <section>
        <h2>Alerts inbox</h2>
        <p>Raised automatically when a published page references a missing or disabled <code>.idea</code>.</p>
        <Inbox />
    </section>
</div>
