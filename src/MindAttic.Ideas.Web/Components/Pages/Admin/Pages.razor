@attribute [Authorize(Policy = MaPolicies.Admin)]
@inject IPageAdminService PagesSvc
@inject IContentCatalog Catalog
@inject ICmsRoleService RolesSvc
@inject MindAttic.Authentication.Services.IUserAdminService UserAdmin

@* Page Management panel — hosted by AdminShell's "Page Management" tab (no own route). *@

<div class="admin-two-pane">
    <div class="admin-list">
        <button class="admin-new" @onclick="StartNew">+ New Page</button>

        @if (pages is not null)
        {
            @* Drop here to pull a page out to the top level. *@
            <div class="admin-droproot @(dragId is not null ? "armed" : "")"
                 @ondragover:preventDefault="true" @ondrop="MoveToTop">
                ⤴ Top level
            </div>

            @foreach (var (node, depth) in Tree())
            {
                <div class="admin-item @(editing is not null && editing.Id == node.Id ? "active" : "") @(dragOverId == node.Id ? "dropinto" : "")"
                     style="margin-left:@(depth * 1.1)rem"
                     draggable="true"
                     @ondragstart="() => dragId = node.Id"
                     @ondragend="() => { dragId = null; dragOverId = null; }"
                     @ondragover:preventDefault="true"
                     @ondragenter="() => dragOverId = node.Id"
                     @ondrop="() => NestUnder(node)"
                     @onclick="() => Edit(node.Id)">
                    <span class="admin-grip" title="Drag to nest">⠿</span>
                    <span class="admin-reorder">
                        <button class="admin-mini" title="Move up" @onclick:stopPropagation="true" @onclick="() => Nudge(node, -1)">▲</button>
                        <button class="admin-mini" title="Move down" @onclick:stopPropagation="true" @onclick="() => Nudge(node, 1)">▼</button>
                    </span>
                    <span class="admin-item-body">
                        <span class="admin-item-name">@(node.Slug.Length == 0 ? "(home)" : "/" + node.Slug)</span>
                        <span class="admin-sub">
                            @node.Title — @node.Kind
                            @if (!node.IsPublished) { <span class="admin-badge">draft</span> }
                            @if (!node.Enabled) { <span class="admin-badge">disabled</span> }
                            @if (node.BodyTrust == ContentTrust.Author) { <span class="admin-badge ok">author</span> }
                        </span>
                    </span>
                </div>
            }
            <p class="admin-hint">Drag a page onto another to nest it; drop on “Top level” to un-nest; ▲▼ reorders siblings.</p>
        }
    </div>

    <div class="admin-editor">
        @if (editing is null)
        {
            <p class="admin-empty">Select a page or create a new one.</p>
        }
        else
        {
            <div class="admin-editor-head">
                <h2>@(isNew ? "New Page" : "/" + editing.Slug)</h2>
                <button class="admin-save" @onclick="Save">Save</button>
                @if (!isNew)
                {
                    <button class="admin-link danger" @onclick="() => SoftDelete(editing.Id)">Delete</button>
                }
            </div>

            @if (!string.IsNullOrEmpty(status))
            {
                <div class="admin-status @(statusBad ? "err" : "ok")">@status</div>
            }

            <details class="admin-page-props" open>
                <summary>
                    Page Properties
                    <span class="admin-props-hint">@(editing.Slug.Length > 0 ? "/" + editing.Slug : "(home)")@(editing.ThemeKey is { Length: > 0 } tk ? " · " + tk : "")</span>
                </summary>
                <div class="admin-grid">
                    <label>Route<input @bind="editing.Slug" placeholder="(blank = home)" /></label>
                    <label>Title<input @bind="editing.Title" /></label>
                    <label>Kind<select @bind="editing.Kind"><option value="Data">Data</option><option value="Code">Code</option></select></label>
                    <label>Parent
                        <select @bind="editing.ParentId">
                            <option value="">(top level)</option>
                            @if (pages is not null)
                            {
                                @foreach (var p in pages.Where(p => p.Id != editing.Id))
                                {
                                    <option value="@p.Id">@(p.Slug.Length == 0 ? "(home)" : "/" + p.Slug)</option>
                                }
                            }
                        </select>
                    </label>
                    <label>Theme
                        <select @bind="editing.ThemeKey">
                            <option value="">(site default)</option>
                            @foreach (var k in UniqueThemeKeys())
                            {
                                <option value="@k">@k</option>
                            }
                        </select>
                    </label>
                    <label>Theme version
                        <select value="@(editing.ThemeVersion?.ToString() ?? "")"
                                @onchange="e => editing.ThemeVersion = e.Value?.ToString() is { Length: > 0 } s && int.TryParse(s, out var v) ? v : null">
                            <option value="">(latest)</option>
                            @foreach (var ver in ThemeVersionsFor(editing.ThemeKey))
                            {
                                <option value="@ver">V@ver</option>
                            }
                        </select>
                    </label>
                    <label class="admin-plugins-label">Plugins
                        <div class="admin-plugin-list">
                            @foreach (var pluginKey in UniquePluginKeys())
                            {
                                var pKey = pluginKey;
                                var latestRef = "Plugin." + pKey;
                                <label class="admin-access-check">
                                    <input type="checkbox"
                                           checked="@editing.ActivePlugins.Any(r => r.StartsWith("Plugin." + pKey, StringComparison.OrdinalIgnoreCase))"
                                           @onchange="e => TogglePlugin(latestRef, (bool)(e.Value ?? false))" />
                                    @pKey
                                </label>
                            }
                        </div>
                    </label>
                    <label>SEO Title<input @bind="editing.SeoTitle" placeholder="(uses Title if blank)" /></label>
                    <label>SEO Description<input @bind="editing.SeoDescription" placeholder="(meta description)" /></label>
                </div>
            </details>

            @if (editing.Kind == PageKind.Data)
            {
                <label class="admin-area">Body HTML<MonacoEditor @bind-Value="editing.BodyHtml" /></label>
                <label class="admin-area">Page CSS<textarea rows="5" @bind="editing.PageCss"></textarea></label>
                <label class="admin-area">Page JS (only runs when saved as Author)<textarea rows="5" @bind="editing.PageJs"></textarea></label>

                @if (Catalog.All.Any(d => d.Kind == ContentKind.Component))
                {
                    <details class="admin-component-palette">
                        <summary>Component Palette (@Catalog.All.Count(d => d.Kind == ContentKind.Component) available)</summary>
                        <div class="admin-palette-list">
                            @foreach (var w in Catalog.All.Where(d => d.Kind == ContentKind.Component).OrderBy(d => d.Key).ThenByDescending(d => d.Version))
                            {
                                var token = "{{ Component." + w.Key + ".V" + w.Version + " }}";
                                <div class="admin-palette-item">
                                    <code>@token</code>
                                    <span class="admin-sub">@w.DisplayName</span>
                                    <button class="admin-mini" @onclick="() => AppendToken(token)">Insert</button>
                                </div>
                            }
                        </div>
                    </details>
                }
            }

            <div class="admin-flags">
                <label><input type="checkbox" @bind="editing.IsPublished" /> Published</label>
                <label><input type="checkbox" @bind="editing.Enabled" /> Enabled</label>
                <label><input type="checkbox" @bind="editing.IsRestricted" @bind:after="OnRestrictedChanged" /> Restricted</label>
            </div>

            @if (editing.IsRestricted)
            {
                <details class="admin-access-control" open>
                    <summary>Access Control</summary>
                    <p class="admin-hint">Restricted pages are only visible to users who match at least one allowed role or are listed by name. Admins always have access.</p>
                    <div class="admin-access-grid">
                        <div>
                            <strong>Allowed roles</strong>
                            @foreach (var role in allRoleNames)
                            {
                                var roleName = role;
                                <label class="admin-access-check">
                                    <input type="checkbox"
                                           checked="@editing.AllowedRoles.Contains(roleName)"
                                           @onchange="e => ToggleRole(roleName, (bool)(e.Value ?? false))" />
                                    @roleName
                                </label>
                            }
                        </div>
                        <div>
                            <strong>Allowed users</strong>
                            <p class="admin-hint">Select users who can view this page regardless of role.</p>
                            @foreach (var u in allUsers)
                            {
                                var uid = u.Id.ToString();
                                <label class="admin-access-check">
                                    <input type="checkbox"
                                           checked="@editing.AllowedUserIds.Contains(uid)"
                                           @onchange="e => ToggleUser(uid, (bool)(e.Value ?? false))" />
                                    @u.UserName @(u.Email is { Length: > 0 } em ? $"({em})" : "")
                                </label>
                            }
                        </div>
                    </div>
                </details>
            }

            @if (!isNew)
            {
                <details class="admin-history">
                    <summary>Page History</summary>
                    <PageHistoryPanel PageId="editing.Id" OnRestored="OnHistoryRestored" />
                </details>
            }
        }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<PageSummary>? pages;
    private PageEditModel? editing;
    private bool isNew;
    private string status = "";
    private bool statusBad;

    // Drag state (the dragged page + the row currently hovered as a drop target).
    private int? dragId;
    private int? dragOverId;

    // Access control data loaded once.
    private IReadOnlyList<string> allRoleNames = [];
    private IReadOnlyList<AuthUserSummary> allUsers = [];

    protected override async Task OnInitializedAsync()
    {
        await Load();
        allRoleNames = await RolesSvc.GetAllRoleNamesAsync();
        allUsers = await UserAdmin.ListAsync();
    }

    private async Task Load() => pages = await PagesSvc.ListAsync();

    // Pre-order tree (depth-tagged). A page whose parent is missing/deleted is treated as a root.
    private IEnumerable<(PageSummary Node, int Depth)> Tree()
    {
        var list = pages ?? Array.Empty<PageSummary>();
        var present = list.Select(p => p.Id).ToHashSet();
        bool IsRoot(PageSummary p) => p.ParentId is not int pid || !present.Contains(pid);
        var children = list.Where(p => !IsRoot(p))
            .GroupBy(p => p.ParentId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.SortOrder).ThenBy(p => p.Slug).ToList());

        var result = new List<(PageSummary, int)>();
        void Walk(PageSummary n, int depth)
        {
            result.Add((n, depth));
            if (children.TryGetValue(n.Id, out var kids))
                foreach (var k in kids) Walk(k, depth + 1);
        }
        foreach (var root in list.Where(IsRoot).OrderBy(p => p.SortOrder).ThenBy(p => p.Slug)) Walk(root, 0);
        return result;
    }

    private int NextSortFor(int? parentId) =>
        (pages ?? Array.Empty<PageSummary>()).Where(p => p.ParentId == parentId)
            .Select(p => p.SortOrder).DefaultIfEmpty(-1).Max() + 1;

    private async Task NestUnder(PageSummary target)
    {
        dragOverId = null;
        if (dragId is not int id || id == target.Id) { dragId = null; return; }
        await PagesSvc.MoveAsync(id, target.Id, NextSortFor(target.Id));   // MoveAsync rejects cycles
        dragId = null;
        await Load();
    }

    private async Task MoveToTop()
    {
        if (dragId is int id) { await PagesSvc.MoveAsync(id, null, NextSortFor(null)); dragId = null; await Load(); }
    }

    // Reorder within siblings: swap the SortOrder values of the two pages being swapped.
    private async Task Nudge(PageSummary node, int dir)
    {
        var sibs = (pages ?? Array.Empty<PageSummary>())
            .Where(p => p.ParentId == node.ParentId).OrderBy(p => p.SortOrder).ThenBy(p => p.Slug).ToList();
        var i = sibs.FindIndex(p => p.Id == node.Id);
        var j = i + dir;
        if (i < 0 || j < 0 || j >= sibs.Count) return;
        var sortI = sibs[i].SortOrder;
        var sortJ = sibs[j].SortOrder;
        // When SortOrders are equal the writes would be no-ops; force a real difference.
        if (sortI == sortJ) { if (dir > 0) sortJ++; else sortI++; }
        await PagesSvc.MoveAsync(sibs[i].Id, sibs[i].ParentId, sortJ);
        await PagesSvc.MoveAsync(sibs[j].Id, sibs[j].ParentId, sortI);
        await Load();
    }

    private void StartNew()
    {
        editing = new PageEditModel { Kind = PageKind.Data, Enabled = true };
        isNew = true; status = "";
    }

    private async Task Edit(int id)
    {
        editing = await PagesSvc.GetAsync(id);
        isNew = false; status = "";
    }

    private async Task Save()
    {
        if (editing is null) return;
        var principal = AuthState is null ? new ClaimsPrincipal() : (await AuthState).User;
        var result = await PagesSvc.SaveAsync(editing, principal);
        if (!result.Ok)
        {
            status = result.Error ?? "Save failed."; statusBad = true;
            return;
        }
        statusBad = false;
        status = result.StampedTrust == ContentTrust.Author
            ? "Saved as Author — your raw HTML/JS is honored."
            : "Saved as Untrusted — inline scripts will be sanitized.";
        isNew = false;
        editing.Id = result.Id;
        await Load();
    }

    private async Task SoftDelete(int id)
    {
        await PagesSvc.SoftDeleteAsync(id);
        editing = null; status = "";
        await Load();
    }

    private async Task OnHistoryRestored()
    {
        if (editing is not null) editing = await PagesSvc.GetAsync(editing.Id);
        status = "Restored from history."; statusBad = false;
        await Load();
    }

    private IEnumerable<string> UniqueThemeKeys() =>
        Catalog.All.Where(d => d.Kind == ContentKind.Theme)
            .Select(d => d.Key).Distinct().OrderBy(k => k);

    private IEnumerable<int> ThemeVersionsFor(string? key) =>
        string.IsNullOrEmpty(key) ? [] :
        Catalog.All.Where(d => d.Kind == ContentKind.Theme && d.Key == key)
            .Select(d => d.Version).OrderBy(v => v);

    private IEnumerable<string> UniquePluginKeys() =>
        Catalog.All.Where(d => d.Kind == ContentKind.Plugin)
            .Select(d => d.Key).Distinct().OrderBy(k => k);

    private void TogglePlugin(string pluginRef, bool add)
    {
        if (editing is null) return;
        if (add) { if (!editing.ActivePlugins.Any(r => string.Equals(r, pluginRef, StringComparison.OrdinalIgnoreCase))) editing.ActivePlugins.Add(pluginRef); }
        else editing.ActivePlugins.RemoveAll(r => r.StartsWith(pluginRef.Split('@')[0], StringComparison.OrdinalIgnoreCase));
    }

    private void AppendToken(string token)
    {
        if (editing is null) return;
        editing.BodyHtml = (editing.BodyHtml ?? "") + token;
    }

    private Task OnRestrictedChanged()
    {
        // Clear access lists when un-restricting so stale entries don't linger.
        if (editing is not null && !editing.IsRestricted)
        {
            editing.AllowedRoles.Clear();
            editing.AllowedUserIds.Clear();
        }
        return Task.CompletedTask;
    }

    private void ToggleRole(string roleName, bool add)
    {
        if (editing is null) return;
        if (add) { if (!editing.AllowedRoles.Contains(roleName)) editing.AllowedRoles.Add(roleName); }
        else editing.AllowedRoles.Remove(roleName);
    }

    private void ToggleUser(string userId, bool add)
    {
        if (editing is null) return;
        if (add) { if (!editing.AllowedUserIds.Contains(userId)) editing.AllowedUserIds.Add(userId); }
        else editing.AllowedUserIds.Remove(userId);
    }
}
