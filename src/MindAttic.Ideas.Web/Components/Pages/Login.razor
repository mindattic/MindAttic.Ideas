@page "/login"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Sign in</PageTitle>

<div class="ma-auth-page">
    <h1>Sign in</h1>
    @* Static-SSR; UserLogin (MindAttic.UiUx) styles the library MaLogin form, which posts to the
       antiforgery-protected /_ma-auth/login endpoint. Failure redirects back here with ?error=1. *@
    <UserLogin ReturnUrl="@ReturnUrl" Error="@(Error == 1)" />
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public int Error { get; set; }
}
