@namespace MindAttic.UiUx.Components
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms

@* Static render + native form POST. user-circle.js handles toggle/submit. No auth-service calls —
   reads the ClaimsPrincipal only. Shows nothing when unauthenticated.
   ShowProfileCircle=false renders a compact inline name + sign-out link without the avatar circle. *@
<AuthorizeView>
    <Authorized Context="ctx">
        @{
            var name = ctx.User.Identity?.Name ?? "User";
            var email = ctx.User.FindFirstValue(ClaimTypes.Email) ?? name;
            var isAdmin = ctx.User.IsInRole("Admin");
        }
        @if (ShowProfileCircle)
        {
            <div class="uc-root" data-uc-click="@ClickAction" style="--uc-size:@(Size)px">
                <button type="button" class="uc-btn" aria-haspopup="true" aria-label="User menu for @name">
                    @if (!string.IsNullOrEmpty(Icon))
                    {
                        @((MarkupString)Icon)
                    }
                    else
                    {
                        @Initials(name)
                    }
                </button>
                <div class="uc-menu">
                    <div class="uc-name">@email</div>
                    <ul class="uc-list">
                        @if (isAdmin)
                        {
                            <li><a href="/admin" class="uc-item">Admin panel</a></li>
                        }
                        <li>
                            <form class="uc-logout-form" method="post" action="/_ma-auth/logout">
                                <AntiforgeryToken />
                                <button type="submit" class="uc-logout">Sign out</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        }
        else
        {
            <span style="display:inline-block;font-size:.85rem;color:#9aa3af;">
                @name
                <form style="display:inline;margin:0;" method="post" action="/_ma-auth/logout">
                    <AntiforgeryToken />
                    <button type="submit" style="background:none;border:none;color:#9aa3af;font-size:.85rem;cursor:pointer;padding:0 0 0 .4rem;font:inherit;">Sign out</button>
                </form>
            </span>
        }
    </Authorized>
</AuthorizeView>

@code {
    /// <summary>Diameter in px (drives --uc-size). Default 40.</summary>
    [Parameter] public int Size { get; set; } = 40;
    /// <summary>Optional raw SVG/icon markup rendered instead of initials.</summary>
    [Parameter] public string? Icon { get; set; }
    /// <summary>"menu" (toggle dropdown, default) or "logout" (click circle = sign out).</summary>
    [Parameter] public string ClickAction { get; set; } = "menu";
    /// <summary>When false, renders a compact inline name + sign-out link without the avatar circle. Default false.</summary>
    [Parameter] public bool ShowProfileCircle { get; set; } = false;

    private static string Initials(string name)
    {
        var parts = name.Split(new[] { ' ', '.', '_', '-', '@' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        return ($"{parts[0][0]}{parts[^1][0]}").ToUpperInvariant();
    }
}
