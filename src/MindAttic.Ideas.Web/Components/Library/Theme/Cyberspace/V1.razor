@namespace MindAttic.Ideas.Theme.Cyberspace
@inherits ThemeBase

@* MindAttic.Ideas.Theme.Cyberspace.V1 — chrome + ONE @Body hole. No zones. Effect layers + body
   prelude mirror the UiUx Themes/Cyberspace shape. Asset URLs MIRROR UiUx deps.json at a pinned tag.
   (Authors reference it case-insensitively in data pages, e.g. <MindAttic.Ideas.Theme.Cyberspace.v1/>.) *@
<div class="cyberspace-sl-fine" aria-hidden="true"></div>
<div class="cyberspace-sl-coarse" aria-hidden="true"></div>
<div class="console-bg-host" aria-hidden="true"></div>
<div class="page">
    @Body
</div>

@code {
    // Pinned jsDelivr tag — must be CI-verified against UiUx Themes/Cyberspace/deps.json.
    private const string Cdn = "https://cdn.jsdelivr.net/gh/mindattic/MindAttic.UiUx@v1.1.0/";

    public override IReadOnlyList<string> GlobalCssUrls { get; } = new[]
    {
        Cdn + "Components/OutfitFont/outfit-font.css",
        Cdn + "Components/AtticFont/attic-font.css",
    };

    public override IReadOnlyList<string> ThemeCssUrls { get; } = new[]
    {
        Cdn + "Components/BackHomeM/back-home-m.css",
        Cdn + "Components/Cyberspace/frontpage.css",
    };

    public override IReadOnlyList<string> ScriptUrls { get; } = new[]
    {
        Cdn + "Components/Cyberspace/loader.js",
        Cdn + "Components/Cyberspace/console-bg.js",
    };
}
