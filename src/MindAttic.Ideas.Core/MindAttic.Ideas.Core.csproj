<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AddRazorSupportForMvc>false</AddRazorSupportForMvc>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MindAttic.Ideas.Abstractions\MindAttic.Ideas.Abstractions.csproj" />
    <!-- The .idea manifest contract + read-only install rules (PackageInstallService reuses them). -->
    <ProjectReference Include="..\MindAttic.Ideas.Packaging\MindAttic.Ideas.Packaging.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="10.0.8" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.8">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <!-- The unified, Vault-backed auth engine. CmsDbContext implements its IAuthDataContext seam.
         Prod uses this clean package (dev auth bypass compiled out). In DEBUG only, the lib is ALSO
         referenced as source below; MSBuild prefers the project output, so a dev build gets the lib's
         Debug build (MA_DEV_AUTH → localhost dev-login bypass). Never present in a release build. -->
    <PackageReference Include="MindAttic.Authentication" Version="1.0.0" />
    <ProjectReference Include="..\..\..\MindAttic.Authentication\src\MindAttic.Authentication\MindAttic.Authentication.csproj" Condition="'$(Configuration)' == 'Debug'" />
    <!-- Rendering-time dependencies the ADR mandates: HTML sanitizer + HTML tokenizer.
         AngleSharp pinned to the exact version HtmlSanitizer requires (no version clash). -->
    <PackageReference Include="HtmlSanitizer" Version="9.0.892" />
    <PackageReference Include="AngleSharp" Version="0.17.1" />
    <!-- Override the vulnerable transitive crypto.Xml 9.0.0 (pulled via SqlClient -> Azure.Identity). -->
    <PackageReference Include="System.Security.Cryptography.Xml" Version="10.0.8" />
  </ItemGroup>

</Project>
